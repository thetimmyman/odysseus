#!/usr/bin/env python3
"""odysseus-stats — aggregated historical model performance (Phase 2).

    odysseus-stats by-model [--task-type TYPE]
    odysseus-stats by-task-type
"""
from __future__ import annotations
import os, sys
sys.path.insert(0, os.path.join(os.path.dirname(__file__), "_lib"))
from cli import quiet_logs, emit, fail, common_parser, run
quiet_logs()

import json
from collections import defaultdict

try:
    from core.database import SessionLocal, RoutingModelRun, RoutingRun, RoutingTask, RoutingModelProfile
    quiet_logs()
except ModuleNotFoundError as e:
    sys.stderr.write(f"error: {e}\nhint: run from repo root with venv active.\n")
    sys.exit(2)

from src.routing_scoring import score_run


def _rows_with_task_type(db, task_type=None):
    q = (
        db.query(RoutingModelRun, RoutingTask.task_type)
        .join(RoutingRun, RoutingModelRun.run_id == RoutingRun.id)
        .join(RoutingTask, RoutingRun.task_id == RoutingTask.id)
    )
    if task_type:
        q = q.filter(RoutingTask.task_type == task_type)
    return q.all()


def cmd_by_model(args):
    db = SessionLocal()
    try:
        rows = _rows_with_task_type(db, args.task_type)
        by_model = defaultdict(lambda: {"attempts": 0, "completed": 0, "rate_limited": 0, "errored": 0,
                                         "total_cost_usd": 0.0, "latencies": [], "scores": []})
        for model_run, task_type in rows:
            profile = db.get(RoutingModelProfile, model_run.model_profile_id)
            key = profile.model if profile else (model_run.model_profile_id or "unknown")
            bucket = by_model[key]
            bucket["attempts"] += 1
            bucket["completed"] += int(bool(model_run.completed))
            bucket["rate_limited"] += int(bool(model_run.rate_limited))
            bucket["errored"] += int(bool(model_run.errored))
            bucket["total_cost_usd"] += model_run.cost_usd or 0.0
            if model_run.latency_ms is not None:
                bucket["latencies"].append(model_run.latency_ms)
            if model_run.scores:
                s = score_run(json.loads(model_run.scores), task_type)
                if s is not None:
                    bucket["scores"].append(s)

        out = []
        for model, b in by_model.items():
            out.append({
                "model": model,
                "attempts": b["attempts"],
                "success_rate": round(b["completed"] / b["attempts"], 3) if b["attempts"] else 0,
                "rate_limited_rate": round(b["rate_limited"] / b["attempts"], 3) if b["attempts"] else 0,
                "errored_rate": round(b["errored"] / b["attempts"], 3) if b["attempts"] else 0,
                "total_cost_usd": round(b["total_cost_usd"], 4),
                "avg_latency_ms": round(sum(b["latencies"]) / len(b["latencies"])) if b["latencies"] else None,
                "avg_score": round(sum(b["scores"]) / len(b["scores"]), 2) if b["scores"] else None,
                "scored_runs": len(b["scores"]),
            })
        out.sort(key=lambda r: (r["avg_score"] is None, -(r["avg_score"] or 0)))
        emit(out, args)
    finally:
        db.close()


def cmd_by_task_type(args):
    db = SessionLocal()
    try:
        rows = _rows_with_task_type(db)
        by_type = defaultdict(lambda: {"attempts": 0, "completed": 0, "total_cost_usd": 0.0, "scores": []})
        for model_run, task_type in rows:
            bucket = by_type[task_type]
            bucket["attempts"] += 1
            bucket["completed"] += int(bool(model_run.completed))
            bucket["total_cost_usd"] += model_run.cost_usd or 0.0
            if model_run.scores:
                s = score_run(json.loads(model_run.scores), task_type)
                if s is not None:
                    bucket["scores"].append(s)
        out = []
        for task_type, b in by_type.items():
            out.append({
                "task_type": task_type,
                "attempts": b["attempts"],
                "success_rate": round(b["completed"] / b["attempts"], 3) if b["attempts"] else 0,
                "total_cost_usd": round(b["total_cost_usd"], 4),
                "avg_score": round(sum(b["scores"]) / len(b["scores"]), 2) if b["scores"] else None,
                "scored_runs": len(b["scores"]),
            })
        emit(out, args)
    finally:
        db.close()


def _build_parser():
    p = common_parser("odysseus-stats", "Aggregated historical model performance (Phase 2).")
    common = p._common_parents[0]
    sub = p.add_subparsers(dest="cmd", required=True)

    pm = sub.add_parser("by-model", parents=[common])
    pm.add_argument("--task-type", help="filter to one task_type")
    pm.set_defaults(func=cmd_by_model)

    pt = sub.add_parser("by-task-type", parents=[common])
    pt.set_defaults(func=cmd_by_task_type)

    return p


if __name__ == "__main__":
    sys.exit(run(_build_parser()))
