#!/usr/bin/env python3
"""odysseus-summarize — recent routing runs and spend.

    odysseus-summarize [--since DAYS] [--limit N]
"""
from __future__ import annotations
import os, sys
sys.path.insert(0, os.path.join(os.path.dirname(__file__), "_lib"))
from cli import quiet_logs, emit, fail, common_parser, run
quiet_logs()

from datetime import datetime, timedelta

try:
    from core.database import SessionLocal, RoutingRun, RoutingTask
    quiet_logs()
except ModuleNotFoundError as e:
    sys.stderr.write(f"error: {e}\nhint: run from repo root with venv active.\n")
    sys.exit(2)


def cmd_default(args):
    db = SessionLocal()
    try:
        since = datetime.utcnow() - timedelta(days=args.since)
        q = (
            db.query(RoutingRun, RoutingTask.title, RoutingTask.task_type)
            .join(RoutingTask, RoutingRun.task_id == RoutingTask.id)
            .filter(RoutingRun.created_at >= since)
            .order_by(RoutingRun.created_at.desc())
            .limit(args.limit)
        )
        out = []
        total_spend = 0.0
        for r, title, task_type in q.all():
            total_spend += r.spend_total_usd or 0.0
            out.append({
                "run_id": r.id, "task_id": r.task_id, "title": title, "task_type": task_type,
                "status": r.status, "spend_total_usd": round(r.spend_total_usd or 0.0, 4),
                "spend_premium_usd": round(r.spend_premium_usd or 0.0, 4),
                "created_at": r.created_at.isoformat() if r.created_at else None,
            })
        emit({"since_days": args.since, "total_spend_usd": round(total_spend, 4), "runs": out}, args)
    finally:
        db.close()


def _build_parser():
    p = common_parser("odysseus-summarize", "Recent routing runs and spend.")
    p.add_argument("--since", type=int, default=7, help="look back this many days (default 7)")
    p.add_argument("--limit", type=int, default=50)
    p.set_defaults(func=cmd_default)
    return p


if __name__ == "__main__":
    sys.exit(run(_build_parser()))
