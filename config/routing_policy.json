{
  "routingPolicyVersion": "1.1",
  "verificationPolicyVersion": "1.1",
  "uiConfigVersion": "1.0",
  "coordinator": {
    "provider": "external",
    "endpointName": null,
    "model": null,
    "temperature": 0.1,
    "maxTokens": 2048
  },
  "maxUntrustedTokens": 256,
  "rawOutputMaxBytes": 262144,
  "remoteSensitivityCeiling": "confidential",
  "verification": {
    "defaultMode": "regression_guard",
    "equivalenceStdoutComparison": true,
    "overconfidenceThreshold": 0.8
  },
  "sandbox": {
    "image": "python:3.12-slim",
    "cpus": 2,
    "memoryGb": 4,
    "pidsLimit": 256,
    "wallClockSeconds": 600,
    "maxOutputBytes": 1048576,
    "mountLabel": "z",
    "allowedCommands": [
      "pytest",
      "python -m pytest",
      "python -m py_compile",
      "npm test",
      "node --check",
      "ruff check",
      "eslint",
      "tsc --noEmit",
      "make test"
    ]
  }
}
